{
  "project": {
    "name": "Traicy Louise Engine v2",
    "version": "2.0.0",
    "engine": "defold-editable",
    "targets": ["defold", "browser", "backend"],
    "entry": "game.project",
    "browserEntry": "game.html",
    "rootForGit": true,
    "backendOptional": true,
    "backendConfig": "criar-backend.yml",
    "editable": true,
    "lowCreditWorkflow": true,
    "compatibility": {
      "defoldMinVersion": "1.0",
      "defoldMaxVersion": "latest",
      "lightEngines": true,
      "minimalFeatures": true
    }
  },
  "sprites": [
    {
      "id": "player",
      "name": "Jogador",
      "path": "resource/sprites/player.json",
      "type": "sprite",
      "image": "resource/sprites/img/placeholder.png"
    }
  ],
  "maps": [
    {
      "id": "level-1",
      "name": "Mapa 1",
      "path": "resource/maps/level-1.json",
      "type": "map"
    }
  ],
  "scenes": [
    {
      "id": "main",
      "name": "Cena Inicial",
      "path": "resource/scenes/main.json",
      "type": "scene"
    }
  ]
}
